---
import '../styles/global.css';
import '../styles/custom.css';
import { Image } from 'astro:assets';
import logo from '../assets/imfs-logo.png';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Iris Musshoff – Energie für Räume und Orte',
  description = 'Feng Shui, Space Healing und energetische Raumklärung. Ich begleite dich dabei, die Energie in deinen Wohn- und Arbeitsräumen ins Gleichgewicht zu bringen.',
  ogImage = '/og-image.png',
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#B7A08A" />
  </head>

  <body class="bg-im-creme text-im-text font-sans antialiased">

    <header
      id="site-header"
      class="fixed top-0 left-0 right-0 z-50 bg-im-creme/95 backdrop-blur-sm border-b border-im-beige transition-shadow duration-300"
    >
      <div class="max-w-5xl mx-auto px-6 py-5">
        <div class="flex justify-between items-center">

          <!-- Logo -->
          <a href="/" aria-label="Iris Musshoff – Startseite">
            <Image
              src={logo}
              alt="Iris Musshoff"
              width={80}
              height={80}
              class="h-10 w-auto"
            />
          </a>

          <!-- Desktop navigation -->
          <nav class="hidden md:flex items-center gap-10" aria-label="Hauptnavigation">
            <a href="#ueber-mich" class="nav-link">Über mich</a>
            <a href="#leistungen" class="nav-link">Leistungen</a>
            <a href="#business" class="nav-link">Business</a>
            <a href="#kontakt" class="btn-primary">Kontakt</a>
          </nav>

          <!-- Mobile hamburger -->
          <button
            id="menu-toggle"
            class="md:hidden p-2 text-im-dark"
            aria-label="Menü öffnen"
            aria-expanded="false"
            aria-controls="mobile-nav"
          >
            <svg
              width="22"
              height="16"
              viewBox="0 0 22 16"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <line x1="0" y1="1" x2="22" y2="1" stroke="currentColor" stroke-width="1.5" />
              <line x1="0" y1="8" x2="22" y2="8" stroke="currentColor" stroke-width="1.5" />
              <line x1="0" y1="15" x2="22" y2="15" stroke="currentColor" stroke-width="1.5" />
            </svg>
          </button>

        </div>

        <!-- Mobile navigation -->
        <nav
          id="mobile-nav"
          class="hidden pt-6 pb-4 border-t border-im-beige mt-4"
          aria-label="Mobile Navigation"
        >
          <div class="flex flex-col gap-5">
            <a href="#ueber-mich" class="nav-link">Über mich</a>
            <a href="#leistungen" class="nav-link">Leistungen</a>
            <a href="#business" class="nav-link">Business</a>
            <a href="#kontakt" class="btn-primary self-start mt-2">Kontakt</a>
          </div>
        </nav>

      </div>
    </header>

    <!-- Spacer for fixed header -->
    <div aria-hidden="true" class="h-18"></div>

    <main>
      <slot />
    </main>

  </body>
</html>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById('menu-toggle');
  const nav = document.getElementById('mobile-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = !nav?.classList.contains('hidden');
    nav?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close menu when navigating to a section
  nav?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      nav.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });

  // Add shadow to header on scroll
  const header = document.getElementById('site-header');
  window.addEventListener(
    'scroll',
    () => {
      header?.classList.toggle('shadow-md', window.scrollY > 30);
    },
    { passive: true },
  );
</script>
