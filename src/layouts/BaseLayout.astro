---
import '../styles/global.css';
import '../styles/custom.css';
import bildmarkeUrl from '../assets/brand/Iris_Bildmarke.svg?url';
import wortmarkeUrl from '../assets/brand/Iris_Wortmarke.svg?url';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Iris Musshoff – Energie für Räume und Orte',
  description = 'Feng Shui, Space Healing und energetische Raumklärung. Ich begleite dich dabei, die Energie in deinen Wohn- und Arbeitsräumen ins Gleichgewicht zu bringen.',
  ogImage = '/og-image.png',
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#B7A08A" />
    <style>
      .site-logo-bildmarke { height: 5rem; width: auto; }
      .site-logo-wortmarke { height: 3rem; width: auto; }
      @media (min-width: 640px) {
        .site-logo-bildmarke { height: 8rem; }
        .site-logo-wortmarke { height: 5rem; }
      }
      /* At md (768px) the desktop nav appears – scale down the logo to avoid collision */
      @media (min-width: 768px) and (max-width: 1023px) {
        .site-logo-bildmarke { height: 5rem; }
        .site-logo-wortmarke { height: 3rem; }
      }
      /* At lg (1024px) there is enough room for the full logo again */
      @media (min-width: 1024px) {
        .site-logo-bildmarke { height: 8rem; }
        .site-logo-wortmarke { height: 5rem; }
      }
    </style>
  </head>

  <body class="bg-im-creme text-im-text font-sans antialiased">

    <header
      id="site-header"
      class="fixed top-0 left-0 right-0 z-50 bg-im-creme/95 backdrop-blur-sm border-b border-im-beige transition-shadow duration-300"
    >
      <div class="max-w-5xl mx-auto px-6 py-2">
        <div class="flex justify-between items-center">

          <!-- Logo -->
          <a href="/" aria-label="Iris Musshoff – Startseite" class="flex items-center gap-2 lg:gap-3 shrink-0">
            <img src={bildmarkeUrl} alt="" class="site-logo-bildmarke" aria-hidden="true" />
            <img src={wortmarkeUrl} alt="Iris Musshoff" class="site-logo-wortmarke hidden sm:block" />
          </a>

          <!-- Desktop navigation -->
          <nav class="hidden md:flex items-center gap-8 lg:gap-10 shrink-0" aria-label="Hauptnavigation">
            <a href="/#ueber-mich" class="nav-link">Über mich</a>
            <a href="/#leistungen" class="nav-link">Leistungen</a>
            <a href="/#business" class="nav-link">Business</a>
            <a href="/#kontakt" class="btn-primary">Kontakt</a>
          </nav>

          <!-- Mobile hamburger -->
          <button
            id="menu-toggle"
            class="md:hidden p-2 text-im-dark"
            aria-label="Menü öffnen"
            aria-expanded="false"
            aria-controls="mobile-nav"
          >
            <svg
              width="22"
              height="16"
              viewBox="0 0 22 16"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <line x1="0" y1="1" x2="22" y2="1" stroke="currentColor" stroke-width="1.5" />
              <line x1="0" y1="8" x2="22" y2="8" stroke="currentColor" stroke-width="1.5" />
              <line x1="0" y1="15" x2="22" y2="15" stroke="currentColor" stroke-width="1.5" />
            </svg>
          </button>

        </div>

        <!-- Mobile navigation -->
        <nav
          id="mobile-nav"
          class="hidden pt-6 pb-4 border-t border-im-beige mt-4"
          aria-label="Mobile Navigation"
        >
          <div class="flex flex-col gap-5">
            <a href="/#ueber-mich" class="nav-link">Über mich</a>
            <a href="/#leistungen" class="nav-link">Leistungen</a>
            <a href="/#business" class="nav-link">Business</a>
            <a href="/#kontakt" class="btn-primary self-start mt-2">Kontakt</a>
          </div>
        </nav>

      </div>
    </header>

    <!-- Spacer for fixed header: height set dynamically via JS -->
    <div id="header-spacer" aria-hidden="true"></div>

    <main>
      <slot />
    </main>

  </body>
</html>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById('menu-toggle');
  const nav = document.getElementById('mobile-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = !nav?.classList.contains('hidden');
    nav?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close menu when navigating to a section
  nav?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      nav.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });

  // Add shadow to header on scroll
  const header = document.getElementById('site-header');
  window.addEventListener(
    'scroll',
    () => {
      header?.classList.toggle('shadow-md', window.scrollY > 30);
    },
    { passive: true },
  );

  // Sync spacer height to actual header height
  const headerSpacer = document.getElementById('header-spacer');
  function syncHeaderSpacer() {
    if (header && headerSpacer) {
      headerSpacer.style.height = header.offsetHeight + 'px';
    }
  }
  syncHeaderSpacer();
  window.addEventListener('resize', syncHeaderSpacer, { passive: true });
</script>
