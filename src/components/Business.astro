---
import { Image } from 'astro:assets';
import businessImg from '../assets/imfs-business.png';

const targetGroups = [
  'Praxen & Gesundheitsberufe',
  'Kanzleien & Beratungsunternehmen',
  'Salons & Studios',
  'Selbstständige',
  'Kleine und große Unternehmen',
];
---

<section id="business" class="py-24 bg-im-beige">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-start">

      <!-- Linke Spalte: alle Textinhalte in Lesereihenfolge -->
      <div>
        <span class="section-label">Für Unternehmen</span>
        <span class="accent-line"></span>
        <h2
          class="font-serif text-3xl md:text-4xl lg:text-5xl font-light text-im-text leading-tight mb-8"
        >
          Erfolg beginnt in deinen Räumen.
        </h2>
        <div class="space-y-5 font-sans text-im-dark leading-relaxed">
          <p class="font-serif text-xl text-im-text leading-relaxed">
            Nutze die Kraft deiner Räume.
          </p>
          <p>
            Die meisten Menschen verbringen einen großen Teil ihres Tages an ihrem
            Arbeitsplatz. Arbeitsräume sollen deshalb nicht nur funktional sein.
            Sie dürfen Menschen stärken, Klarheit fördern und eine Atmosphäre
            schaffen, in der konzentriertes Arbeiten leicht wird.
          </p>
          <p>Oft sind es kleine Veränderungen, die eine große Wirkung entfalten.</p>
          <p>
            Mehr Konzentration.<br />
            Mehr Klarheit.<br />
            Mehr Leichtigkeit.
          </p>
        </div>

        <!-- Warum ich die Arbeit mit Unternehmen liebe -->
        <div class="mt-12 pt-10 border-t border-im-taupe/30">
          <h3 class="font-serif text-xl text-im-text mb-2">
            Warum ich die Arbeit mit Unternehmen liebe
          </h3>
          <span class="block w-8 h-px bg-im-taupe mb-6"></span>
          <p class="font-sans text-sm text-im-dark leading-relaxed">
            Seit über 30 Jahren unterstütze ich als Unternehmerin viele Betriebe im
            kaufmännischen Bereich. Gerade deshalb begeistert es mich, wenn
            Veränderungen in Arbeitsräumen nicht nur das Miteinander verbessern,
            sondern sich auch im Unternehmen zeigen. Für mich ist das jedes Mal
            aufs Neue faszinierend.
          </p>
        </div>

        <!-- Abschluss-Zitat -->
        <p class="mt-10 font-serif text-xl md:text-2xl text-im-text italic leading-relaxed">
          Erfolg beginnt nicht bei den Zahlen.<br />
          Erfolg beginnt in den Räumen,<br />
          in denen Menschen arbeiten.<br />
          Erfolg ist nicht nur spürbar.<br />
          Erfolg ist messbar.
        </p>
      </div>

      <!-- Rechte Spalte: Liste + Bild, leicht versetzt nach unten -->
      <div class="md:pt-16">

        <!--
          Alternative Formulierungen für "Ich begleite unter anderem":
          - "Ideal für ..."
          - "Passend für ..."
          - "Sinnvoll für ..."
          - "Meine Arbeit unterstützt ..."
          Aktuell: "Ich begleite unter anderem"
        -->
        <h3 class="font-serif text-xl text-im-text mb-2">Ich begleite unter anderem</h3>
        <span class="block w-8 h-px bg-im-taupe mb-7"></span>
        <ul class="space-y-4">
          {
            targetGroups.map(item => (
              <li class="flex items-center gap-3 font-sans text-sm text-im-dark">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" class="w-3.5 h-3.5 text-im-taupe shrink-0" fill="currentColor" aria-hidden="true"><path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"/></svg>
                {item}
              </li>
            ))
          }
        </ul>

        <!-- Portrait direkt unter der Liste -->
        <div class="mt-10">
          <Image
            src={businessImg}
            alt="Iris Musshoff"
            width={500}
            height={400}
            class="w-full h-auto"
          />
        </div>

      </div>
    </div>
  </div>
</section>
