---

<section class="placeholder-hero-bg min-h-[85vh] flex items-center">
  <div class="max-w-5xl mx-auto px-6 py-24 w-full">
    <div class="grid md:grid-cols-2 gap-16 items-center">

      <!-- Text -->
      <div>
        <span class="section-label">Feng Shui · Space Healing · Energiearbeit</span>
        <span class="accent-line"></span>
        <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl font-light text-im-text leading-[1.1] tracking-wide">
          Energie für<br />Räume und<br />Orte
        </h1>
        <p class="mt-8 font-sans text-lg text-im-dark leading-relaxed max-w-md">
          Räume und Orte können uns stärken, unterstützen und neue Kraft schenken.
          Ich begleite Menschen dabei, die Energie in ihren Wohn- und Arbeitsräumen
          wieder ins Gleichgewicht zu bringen.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a href="#kontakt" class="btn-primary">Kontakt aufnehmen</a>
          <a href="#leistungen" class="btn-secondary">Leistungen entdecken</a>
        </div>
      </div>

      <!-- CSS-Bildplatzhalter -->
      <div class="hidden md:flex justify-end">
        <div class="w-72 lg:w-80 aspect-[3/4] placeholder-portrait-bg relative overflow-hidden">
          <div class="absolute inset-4 border border-im-taupe/30"></div>
          <div class="absolute bottom-8 left-8 right-8">
            <div class="h-px bg-im-taupe/40 w-full mb-2"></div>
            <div class="h-px bg-im-taupe/25 w-2/3"></div>
          </div>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="font-sans text-xs tracking-[0.3em] uppercase text-im-taupe/60"
              >Bildplatz</span
            >
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
