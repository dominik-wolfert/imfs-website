---
const testimonials = [
  {
    quote:
      'Iris hat mit ganz viel Ruhe und Feingefühl bei mir gearbeitet. Seitdem gehe ich bewusster und mit mehr Dankbarkeit in meine Räume, und ich merke besonders abends, dass meine Gedanken beim Einschlafen ruhiger geworden sind. Danke dafür. Ich bin gespannt, wie sich alles weiter entwickelt.',
    name: 'Bianca F., Paderborn',
  },
  {
    quote:
      'Seit Iris in meinen Räumen gearbeitet hat, hat sich die Energie spürbar verändert. Es ist deutlich mehr Leichtigkeit eingekehrt, und es herrscht ein sehr schönes, harmonisches Miteinander. Die Atmosphäre fühlt sich klarer, wärmer und einfach stimmiger an. Besonders bemerkenswert ist, dass selbst meine Kunden – ganz unabhängig von mir – diese positive Veränderung wahrnehmen und die besondere, angenehme Frequenz ansprechen. Ich bin sehr dankbar für diese wertvolle Arbeit und kann Iris von Herzen weiterempfehlen.',
    name: 'Anette K., Warendorf',
  },
];
---

<section id="stimmen" class="py-24 bg-im-beige">
  <div class="max-w-5xl mx-auto px-6">

    <div class="mb-16">
      <span class="section-label">Stimmen</span>
      <span class="accent-line"></span>
      <h2
        class="font-serif text-3xl md:text-4xl lg:text-5xl font-light text-im-text leading-tight max-w-lg"
      >
        Stimmen meiner Kunden.
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {
        testimonials.map(t => (
          <div class="bg-white border-t-2 border-im-taupe p-8 flex flex-col">
            <blockquote class="font-serif text-lg text-im-text leading-relaxed flex-1">
              „{t.quote}"
            </blockquote>
            <p class="mt-8 font-sans text-xs tracking-widest uppercase text-im-taupe">
              {t.name}
            </p>
          </div>
        ))
      }
    </div>

  </div>
</section>
