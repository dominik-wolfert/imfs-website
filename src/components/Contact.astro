---
import { Image } from 'astro:assets';
import logoImg from '../assets/imfs-logo.png';
---

<section id="kontakt" class="py-24 bg-white">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-start">

      <!-- Intro -->
      <div>
        <span class="section-label">Kontakt</span>
        <span class="accent-line"></span>
        <h2
          class="font-serif text-3xl md:text-4xl lg:text-5xl font-light text-im-text leading-tight mb-8"
        >
          Ich freue mich,<br />von Dir zu hören.
        </h2>
        <p class="font-sans text-im-dark leading-relaxed mb-10">
          Unverbindliches und kostenloses Erstgespräch – online oder bei mir zu Hause.
          Schreib mir einfach, ich melde mich bei dir.
        </p>
        <div class="space-y-4">
          <div class="flex items-center gap-4">
            <span class="w-5 h-px bg-im-taupe shrink-0"></span>
            <a
              href="mailto:kontakt@irismusshoff.de"
              class="font-sans text-im-text hover:text-im-dark transition-colors"
            >
              kontakt@irismusshoff.de
            </a>
          </div>
        </div>
        <div class="mt-10 opacity-40">
          <Image src={logoImg} alt="Iris Musshoff" width={52} height={52} class="h-10 w-auto" />
        </div>
      </div>

      <!-- Formular -->
      <div>
        <!--
          TODO: Formspree-ID eintragen.
          1. Konto anlegen auf formspree.io
          2. Neues Formular erstellen für iris-musshoff.de
          3. YOUR_FORM_ID ersetzen (z. B. xzdjlgyd)
          4. Datenschutz: Data Processing Agreement bei Formspree abschließen
        -->
        <form action="https://formspree.io/f/xdarpzqo" method="POST" class="space-y-6">
          <!-- Honeypot against bots -->
          <input type="text" name="_gotcha" class="hidden" aria-hidden="true" tabindex="-1" />

          <div>
            <label
              for="contact-name"
              class="block font-sans text-xs tracking-widest uppercase text-im-dark mb-2"
            >
              Name <span class="text-im-taupe" aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="contact-name"
              name="name"
              required
              autocomplete="name"
              class="form-input"
            />
          </div>

          <div>
            <label
              for="contact-email"
              class="block font-sans text-xs tracking-widest uppercase text-im-dark mb-2"
            >
              E-Mail <span class="text-im-taupe" aria-hidden="true">*</span>
            </label>
            <input
              type="email"
              id="contact-email"
              name="email"
              required
              autocomplete="email"
              class="form-input"
            />
          </div>

          <div>
            <label
              for="contact-message"
              class="block font-sans text-xs tracking-widest uppercase text-im-dark mb-2"
            >
              Nachricht <span class="text-im-taupe" aria-hidden="true">*</span>
            </label>
            <textarea
              id="contact-message"
              name="message"
              rows="5"
              required
              class="form-input resize-none"
            ></textarea>
          </div>

          <!-- DSGVO-Einwilligung -->
          <div>
            <label class="flex items-start gap-3 cursor-pointer">
              <input
                type="checkbox"
                name="dsgvo"
                required
                class="mt-1 shrink-0 w-4 h-4 border border-im-taupe accent-im-taupe cursor-pointer"
              />
              <span class="font-sans text-sm text-im-dark leading-relaxed">
                Ich habe die
                <a
                  href="/datenschutz"
                  class="underline decoration-im-taupe hover:text-im-text transition-colors"
                >
                  Datenschutzerklärung
                </a>
                gelesen und stimme der Verarbeitung meiner Daten zur Bearbeitung
                meiner Anfrage zu. <span class="text-im-taupe" aria-hidden="true">*</span>
              </span>
            </label>
          </div>

          <button type="submit" class="btn-primary w-full">Nachricht senden</button>
        </form>
      </div>

    </div>
  </div>
</section>
