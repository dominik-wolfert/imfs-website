---
import logoUrl from '../assets/brand/Iris_Logo.svg?url';
const year = new Date().getFullYear();
---

<footer class="bg-im-text py-12">
  <div class="max-w-5xl mx-auto px-6">

    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-8">

      <!-- Brand -->
      <div>
        <img
          src={logoUrl}
          alt="Iris Musshoff"
          class="h-16 w-auto brightness-0 invert opacity-70"
        />
      </div>

      <!-- Links -->
      <nav aria-label="Footer-Navigation">
        <ul class="flex flex-wrap gap-6">
          <li>
            <a
              href="/impressum"
              class="font-sans text-xs text-im-beige tracking-widest uppercase hover:text-im-creme transition-colors"
            >
              Impressum
            </a>
          </li>
          <li>
            <a
              href="/datenschutz"
              class="font-sans text-xs text-im-beige tracking-widest uppercase hover:text-im-creme transition-colors"
            >
              Datenschutz
            </a>
          </li>
          <li>
            <a
              href="/#kontakt"
              class="font-sans text-xs text-im-beige tracking-widest uppercase hover:text-im-creme transition-colors"
            >
              Kontakt
            </a>
          </li>
        </ul>
      </nav>

    </div>

    <div class="border-t border-im-dark mt-8 pt-8 text-center">
      <p class="font-sans text-xs text-im-taupe">
        © {year} Iris Musshoff · Alle Rechte vorbehalten
      </p>
    </div>

  </div>
</footer>
