---
interface PricingItem {
  label: string;
  price: string;
}

interface Service {
  eyebrow: string;
  name: string;
  description: string;
  features: string[];
  priceLabel: string;
  pricing: PricingItem[];
}

const services: Service[] = [
  {
    eyebrow: 'Einstieg',
    name: 'Raum-Impuls',
    description: 'Der Einstieg für mehr Klarheit und Energie in deinem Raum.',
    features: [
      'Online oder vor Ort',
      'Analyse eines Raumes oder Ortes',
      'Erste Feng-Shui-Analyse',
      'Konkrete Empfehlungen',
    ],
    priceLabel: 'Investition',
    pricing: [{ label: '', price: 'ab 303 €' }],
  },
  {
    eyebrow: 'Ganzheitlich',
    name: 'Raum- & Ortsbalance',
    description: 'Die umfassende Analyse für Wohn- und Arbeitsräume.',
    features: [
      'Feng-Shui-Analyse',
      'Energetische Raumklärung',
      'Ortsklärung',
      'Optimierung des Energieflusses',
    ],
    priceLabel: 'Investition',
    pricing: [
      { label: 'Wohnung bis 100 m²', price: 'ab 444 €' },
      { label: 'Business / Praxis / Büro', price: 'ab 555 €' },
      { label: 'Einfamilienhaus', price: 'ab 999 €' },
      { label: 'Grundstücke', price: 'auf Anfrage' },
    ],
  },
  {
    eyebrow: 'Begleitung',
    name: 'Begleitung Raum & Leben',
    description: 'Viele Menschen wissen nach einer Beratung, was zu tun wäre – im Alltag fehlt jedoch oft die Zeit oder Klarheit für die Umsetzung. Ich begleite dich dabei, deine Räume Schritt für Schritt zu einem Ort der Kraft, Harmonie und Lebendigkeit zu entwickeln.',
    features: [
      'Persönliche Begleitung',
      'Regelmäßige Impulse',
      'Unterstützung bei Veränderungen',
      'Raum für Fragen',
      'Begleitung über mehrere Monate',
    ],
    priceLabel: 'Investition',
    pricing: [{ label: '', price: 'ab 222 € / Monat' }],
  },
];
---

<section id="leistungen" class="py-24 bg-im-creme">
  <div class="max-w-5xl mx-auto px-6">

    <!-- Header -->
    <div class="mb-16">
      <span class="section-label">Leistungen</span>
      <span class="accent-line"></span>
      <h2
        class="font-serif text-3xl md:text-4xl lg:text-5xl font-light text-im-text leading-tight max-w-lg"
      >
        Auszug meiner<br />Leistungen.
      </h2>
      <p class="mt-6 font-sans text-im-dark leading-relaxed max-w-xl">
        Räume und Orte beeinflussen unser Wohlbefinden jeden Tag. Mit Feng Shui,
        Space Healing und energetischer Raum- und Ortsklärung unterstütze ich Menschen
        dabei, Wohnräume, Arbeitsplätze und Grundstücke in Orte der Kraft und Balance
        zu verwandeln.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid md:grid-cols-3 gap-8">
      {
        services.map(service => (
          <div class="bg-white border-t-2 border-im-taupe p-8 flex flex-col">
            <span class="section-label mb-4">{service.eyebrow}</span>
            <h3 class="font-serif text-2xl font-medium text-im-text mb-3">{service.name}</h3>
            <p class="font-sans text-im-dark leading-relaxed mb-6 flex-1">{service.description}</p>

            <ul class="space-y-2 mb-8">
              {service.features.map(feature => (
                <li class="flex items-start gap-3 font-sans text-sm text-im-dark">
                  <span class="text-im-taupe mt-0.5 shrink-0">—</span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

            <div class="border-t border-im-beige pt-6 mt-auto">
              <span class="section-label mb-3 block">{service.priceLabel}</span>
              <div class="space-y-2">
                {service.pricing.map(item =>
                  item.label ? (
                    <div class="flex justify-between items-baseline gap-4">
                      <span class="font-sans text-sm text-im-dark">{item.label}</span>
                      <span class="font-sans text-sm font-medium text-im-text whitespace-nowrap">
                        {item.price}
                      </span>
                    </div>
                  ) : (
                    <p class="font-serif text-2xl text-im-text">{item.price}</p>
                  )
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-16 text-center">
      <a href="#kontakt" class="btn-primary">Angebot anfragen</a>
    </div>

  </div>
</section>
